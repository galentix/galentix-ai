# Galentix AI Environment Configuration
# Copy this file to .env and adjust values for your deployment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application
APP_NAME=Galentix AI
APP_VERSION=2.0.0
APP_ENV=production          # production, development
DEBUG=false
LOG_LEVEL=info

# Server
HOST=0.0.0.0
PORT=8080

# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL=sqlite+aiosqlite:///data/galentix.db

# =============================================================================
# LLM SETTINGS
# =============================================================================

# LLM Engine (ollama, vllm)
LLM_ENGINE=ollama

# Model to use (must be installed in Ollama)
LLM_MODEL=llama3:8b

# Ollama URL
OLLAMA_URL=http://ollama:11434

# vLLM URL (if using vllm engine)
VLLM_URL=http://vllm:8000

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# =============================================================================
# RAG SETTINGS
# =============================================================================

RAG_ENABLED=true
CHROMA_PATH=/data/chroma
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# SEARCH SETTINGS
# =============================================================================

SEARCH_ENABLED=true
SEARXNG_URL=http://searxng:8080
SEARCH_MAX_RESULTS=5

# =============================================================================
# SECURITY
# =============================================================================

SECRET_KEY=change-me-in-production
API_KEY=

# =============================================================================
# STORAGE
# =============================================================================

UPLOAD_DIR=/data/documents
MAX_UPLOAD_SIZE=52428800    # 50MB in bytes

# =============================================================================
# CORS (Production - restrict to your domain)
# =============================================================================

CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# =============================================================================
# DOCKER SERVICES
# =============================================================================

# Ollama
OLLAMA_PORT=11434

# SearXNG
SEARXNG_PORT=8888